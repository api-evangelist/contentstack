  "info": {
    "_postman_id": "511e3ec6-84be-48ec-82cd-f0ebfdcd8f3e",
    "name": "Contentstack Generative AI API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Contentstack Generative AI API provides an endpoint for generating AI-powered content using a Brand Kit's knowledge vault and voice profiles. It acts as a communication channel between the vector database and large language models, processing prompts with retrieval augmented generation (RAG) to produce brand-aligned content. The API supports optional knowledge vault retrieval and voice profile application to ensure generated content adheres to the organization's brand guidelines and writing style.\n\nContact Support:\n Name: Contentstack Support",
      "type": "text/plain"
    }
  }
