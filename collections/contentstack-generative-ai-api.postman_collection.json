      "id": "c90993bb-3bf5-4e25-95da-8c09413695e2",
      "name": "Generative AI",
      "description": {
        "content": "The Generative AI endpoint processes prompts using retrieval augmented generation, retrieving relevant brand knowledge and applying voice profile style guidelines to produce on-brand content. Responses are returned as streaming dictionary responses for real-time content delivery.",
        "type": "text/plain"
      },
