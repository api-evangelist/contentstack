      "name": "Knowledge Vault",
      "description": {
        "content": "Knowledge Vault endpoints allow developers to programmatically manage the brand knowledge content stored in a Brand Kit's vector database. Content items are vectorized upon ingestion and used to provide contextually relevant information during AI content generation.",
        "type": "text/plain"
      },
